{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://radhin-portfolio-backend.onrender.com/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://radhin-portfolio-backend.onrender.com/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
